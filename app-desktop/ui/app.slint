import { Button, HorizontalBox, VerticalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Free PDF Editor";
    min-width: 900px;
    min-height: 700px;

    in property <image>  page-image;
    in property <string> status-text:   "Ready";
    in property <int>    page-count:    0;
    in property <int>    current-page:  0;
    in property <float>  zoom-level:    1.0;
    in property <bool>   can-undo:      false;
    in property <bool>   can-redo:      false;
    in property <string> document-title: "";

    callback open-document();
    callback save-document();
    callback save-document-as();
    callback close-document();
    callback zoom-in();
    callback zoom-out();
    callback zoom-reset();
    callback next-page();
    callback prev-page();
    callback undo();
    callback redo();
    callback add-highlight();
    callback add-note();
    callback delete-current-page();
    callback rotate-current-page();

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 44px;
            background: #2c2c2e;

            HorizontalBox {
                padding: 4px;
                spacing: 4px;
                alignment: start;

                Button { text: "Open";      clicked => { root.open-document(); } }
                Button { text: "Save";      clicked => { root.save-document(); } }
                Button { text: "Save As";   clicked => { root.save-document-as(); } }
                Button { text: "Close";     clicked => { root.close-document(); } }

                Rectangle { width: 8px; }

                Button { text: "Undo";      enabled: root.can-undo; clicked => { root.undo(); } }
                Button { text: "Redo";      enabled: root.can-redo; clicked => { root.redo(); } }

                Rectangle { width: 8px; }

                Button { text: "Zoom -";    clicked => { root.zoom-out(); } }
                Button { text: "Zoom +";    clicked => { root.zoom-in(); } }
                Button { text: "100%";      clicked => { root.zoom-reset(); } }

                Rectangle { width: 8px; }

                Button { text: "Prev";      clicked => { root.prev-page(); } }
                Button { text: "Next";      clicked => { root.next-page(); } }

                Rectangle { width: 8px; }

                Button { text: "Highlight"; clicked => { root.add-highlight(); } }
                Button { text: "Note";      clicked => { root.add-note(); } }

                Rectangle { width: 8px; }

                Button { text: "Del Page";  clicked => { root.delete-current-page(); } }
                Button { text: "Rotate";    clicked => { root.rotate-current-page(); } }
            }
        }

        HorizontalBox {
            padding: 0px;
            spacing: 0px;

            ScrollView {
                min-width: 800px;

                VerticalBox {
                    alignment: center;
                    padding: 16px;

                    Image {
                        source: root.page-image;
                        image-fit: contain;
                        min-width: 595px;
                        min-height: 842px;
                    }
                }
            }
        }

        Rectangle {
            height: 26px;
            background: #e5e5ea;

            HorizontalBox {
                padding-top: 4px;
                padding-bottom: 4px;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 16px;
                alignment: start;

                Text {
                    text: root.document-title == "" ? "No document" : root.document-title;
                    font-size: 11px;
                    color: #333;
                }

                Text {
                    text: root.page-count > 0
                        ? "Page " + root.current-page + " / " + root.page-count
                        : "";
                    font-size: 11px;
                    color: #333;
                }

                Text {
                    text: root.status-text;
                    font-size: 11px;
                    color: #555;
                }
            }
        }
    }
}
