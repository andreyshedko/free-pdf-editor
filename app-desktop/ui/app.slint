import { Button, HorizontalBox, VerticalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Free PDF Editor";
    min-width: 900px;
    min-height: 700px;
    background: #0b1220;

    in property <image>  page-image;
    in property <string> status-text:   "Ready";
    in property <int>    page-count:    0;
    in property <int>    current-page:  0;
    in property <float>  zoom-level:    1.0;
    in property <bool>   can-undo:      false;
    in property <bool>   can-redo:      false;
    in property <string> document-title: "";
    in property <image>  thumbnail-image;
    property <int> active-menu: 0;
    property <bool> compact-mode: false;
    property <bool> menu-open: false;
    property <bool> has-document: root.page-count > 0;
    property <length> menu-button-width: root.compact-mode ? 86px : 96px;
    property <length> menu-row-spacing: root.compact-mode ? 6px : 8px;
    property <length> header-height: root.compact-mode ? 72px : 86px;
    property <[string]> menu-model: ["[F] File", "[E] Edit", "[V] View", "[A] Annotate", "[P] Page", "[T] Tools", "[L] License"];
    property <string> active-menu-label:
        root.active-menu == 0 ? "[F] File" :
        root.active-menu == 1 ? "[E] Edit" :
        root.active-menu == 2 ? "[V] View" :
        root.active-menu == 3 ? "[A] Annotate" :
        root.active-menu == 4 ? "[P] Page" :
        root.active-menu == 5 ? "[T] Tools" :
        "[L] License";
    property <string> shortcut-tooltip:
        root.active-menu == 0 ? "[O] Open: Ctrl+O\n[S] Save: Ctrl+S\n[SA] Save As: Ctrl+Shift+S" :
        root.active-menu == 1 ? "[U] Undo: Ctrl+Z\n[R] Redo: Ctrl+Y" :
        root.active-menu == 2 ? "[+] Zoom +: Ctrl++\n[-] Zoom -: Ctrl+-\n[1] 100%: Ctrl+0" :
        root.active-menu == 4 ? "[>] Next: PageDown or RightArrow\n[<] Prev: PageUp or LeftArrow" :
        "No keyboard shortcuts assigned for this menu.";

    property <brush> color-bg: #0b1220;
    property <brush> color-header: #101a2e;
    property <brush> color-header-2: #1a2742;
    property <brush> color-panel: #121c30;
    property <brush> color-panel-soft: #1a2740;
    property <brush> color-border: #2c3c5b;
    property <brush> color-text: #e7ecf4;
    property <brush> color-muted: #9eb0cb;
    property <brush> color-accent: #2dd4bf;
    property <brush> color-canvas: #edf2ff;

    // License display (read-only from the UI; set by the controller).
    in property <string> license-type:   "Personal";
    in property <string> license-expiry: "";

    callback open-document();
    callback save-document();
    callback save-document-as();
    callback close-document();
    callback zoom-in();
    callback zoom-out();
    callback zoom-reset();
    callback next-page();
    callback prev-page();
    callback undo();
    callback redo();
    callback add-highlight();
    callback add-note();
    callback delete-current-page();
    callback rotate-current-page();
    callback tools-insert-text();
    callback tools-modify-text();
    callback tools-font-substitute();
    callback tools-insert-image();
    callback tools-replace-image();
    callback tools-set-password();
    callback tools-redact-region();
    callback tools-apply-ocr();
    callback tools-reorder-pages();
    callback tools-merge-document();
    callback tools-create-field();
    callback tools-set-field-value();
    callback tools-detect-fields();
    callback tools-export-form-data();
    callback upgrade-license();
    /// Triggered when the user wants to activate a commercial license file.
    /// In debug builds, the controller reads the ACTIVATE_LICENSE environment
    /// variable, validates and reloads. In release builds this action is not
    /// available (file-picker integration is pending).
    callback activate-license();
    callback menu-action-selected(menu-index: int, action-index: int);
    forward-focus: keyboard_scope;

    init => {
        root.compact-mode = root.width < 1160px;
    }

    changed width => {
        root.compact-mode = root.width < 1160px;
    }

    keyboard_scope := FocusScope {
        width: parent.width;
        height: parent.height;

        key-pressed(event) => {
            if (event.text == Key.Escape && root.menu-open) {
                root.menu-open = false;
                return accept;
            }

            if (event.modifiers.control && event.modifiers.shift && (event.text == "S" || event.text == "s")) {
                root.save-document-as();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && (event.text == "O" || event.text == "o")) {
                root.open-document();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && (event.text == "S" || event.text == "s")) {
                root.save-document();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && (event.text == "Z" || event.text == "z")) {
                root.undo();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && (event.text == "Y" || event.text == "y")) {
                root.redo();
                return accept;
            }

            if (event.modifiers.control && (event.text == "+" || event.text == "=")) {
                root.zoom-in();
                return accept;
            }

            if (event.modifiers.control && event.text == "-") {
                root.zoom-out();
                return accept;
            }

            if (event.modifiers.control && event.text == "0") {
                root.zoom-reset();
                return accept;
            }

            if (event.text == Key.PageDown || event.text == Key.RightArrow) {
                root.next-page();
                return accept;
            }

            if (event.text == Key.PageUp || event.text == Key.LeftArrow) {
                root.prev-page();
                return accept;
            }

            return reject;
        }

        VerticalBox {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: root.header-height;
            background: root.color-header;
            border-width: 1px;
            border-color: root.color-border;
            animate height { duration: 180ms; }

            VerticalBox {
                padding-top: root.compact-mode ? 6px : 8px;
                padding-bottom: root.compact-mode ? 6px : 8px;
                padding-left: root.compact-mode ? 8px : 10px;
                padding-right: root.compact-mode ? 8px : 10px;
                spacing: root.compact-mode ? 4px : 6px;

                HorizontalBox {
                    spacing: 10px;

                    Text {
                        text: "Free PDF Editor";
                        color: root.color-text;
                        font-size: root.compact-mode ? 13px : 15px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }

                    Text {
                        text: root.document-title == "" ? "No document" : root.document-title;
                        color: root.color-muted;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                HorizontalBox {
                    spacing: root.menu-row-spacing;
                    alignment: start;

                    for menu_name[idx] in root.menu-model : Button {
                        width: root.menu-button-width;
                        text: menu_name;
                        clicked => {
                            if (root.active-menu == idx) {
                                root.menu-open = !root.menu-open;
                            } else {
                                root.active-menu = idx;
                                root.menu-open = true;
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 0px;
            background: transparent;
        }

        Rectangle {
            height: 2px;
            background: root.color-accent;
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: transparent;

            HorizontalBox {
                padding: 0px;
                spacing: 0px;

                Rectangle {
                    width: root.compact-mode ? 178px : 220px;
                    background: root.color-panel;
                    border-width: 1px;
                    border-color: root.color-border;
                    animate width { duration: 180ms; }

                VerticalBox {
                    padding: root.compact-mode ? 8px : 12px;
                    spacing: root.compact-mode ? 6px : 10px;

                    Text {
                        text: "Page Preview";
                        font-size: 13px;
                        font-weight: 600;
                        color: root.color-text;
                    }

                    Text {
                        text: root.page-count > 0 ? "Current: " + root.current-page + " / " + root.page-count : "No document loaded";
                        font-size: 11px;
                        color: root.color-muted;
                    }

                    Rectangle {
                        min-height: root.compact-mode ? 170px : 240px;
                        background: root.color-panel-soft;
                        border-width: 1px;
                        border-color: root.color-border;
                        border-radius: 8px;
                        animate min-height { duration: 180ms; }

                        Image {
                            width: parent.width;
                            height: parent.height;
                            source: root.thumbnail-image;
                            image-fit: contain;
                        }
                    }
                }
                }

                Rectangle {
                    min-width: 800px;
                    background: root.color-canvas;
                    border-width: 1px;
                    border-color: #cdd8f0;

                    TouchArea {
                        width: parent.width;
                        height: parent.height;
                        scroll-event(ev) => {
                            if (ev.delta_y < -2px) {
                                root.next-page();
                                return accept;
                            }
                            if (ev.delta_y > 2px) {
                                root.prev-page();
                                return accept;
                            }
                            return reject;
                        }
                    }

                    ScrollView {
                        width: parent.width;
                        height: parent.height;

                        VerticalBox {
                            alignment: center;
                            padding: root.compact-mode ? 14px : 24px;
                            animate padding { duration: 180ms; }

                            Rectangle {
                                border-width: 1px;
                                border-color: #c5d1ec;
                                border-radius: 10px;
                                background: #ffffff;
                                VerticalBox {
                                    padding: 12px;
                                    spacing: 0px;

                                    Image {
                                        source: root.page-image;
                                        image-fit: contain;
                                        min-width: 595px;
                                        min-height: 842px;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if root.menu-open : TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => {
                    root.menu-open = false;
                }
            }
        }

        Rectangle {
            height: root.compact-mode ? 24px : 30px;
            background: root.color-header;
            border-width: 1px;
            border-color: root.color-border;
            animate height { duration: 180ms; }

            HorizontalBox {
                padding-top: 4px;
                padding-bottom: 4px;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 16px;
                alignment: start;

                Text {
                    text: root.document-title == "" ? "No document" : root.document-title;
                    font-size: 11px;
                    color: root.color-text;
                }

                Text {
                    text: root.page-count > 0
                        ? "Page " + root.current-page + " / " + root.page-count
                        : "";
                    font-size: 11px;
                    color: root.color-muted;
                }

                Text {
                    text: root.status-text;
                    font-size: 11px;
                    color: root.color-accent;
                }
            }
        }

        // License info bar – shows license type, expiry date, and upgrade button.
        Rectangle {
            height: root.compact-mode ? 24px : 30px;
            background: #101a2d;
            border-width: 1px;
            border-color: root.color-border;
            animate height { duration: 180ms; }

            HorizontalBox {
                padding-top: 4px;
                padding-bottom: 4px;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 16px;
                alignment: start;

                Text {
                    text: "License: " + root.license-type;
                    font-size: 11px;
                    color: root.color-text;
                }

                Text {
                    text: root.license-expiry != "" ? "Expires: " + root.license-expiry : "";
                    font-size: 11px;
                    color: root.color-muted;
                }
            }
        }

        }

        // Global dropdown overlay (rendered last) so it stays above all UI layers,
        // similar to appending a menu body to document body in web apps.
        if root.menu-open : Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: transparent;

            // Click outside closes the menu.
            TouchArea {
                width: parent.width;
                y: root.header-height;
                height: parent.height - root.header-height;
                clicked => { root.menu-open = false; }
            }

            Rectangle {
                x: (root.compact-mode ? 8px : 10px) + root.active-menu * (root.menu-button-width + root.menu-row-spacing);
                y: root.header-height;
                width: root.compact-mode ? 200px : 230px;
                height: root.active-menu == 5
                    ? (root.compact-mode ? 372px : 420px)
                    : (root.compact-mode ? 128px : 150px);
                background: root.color-panel;
                border-width: 1px;
                border-color: root.color-border;
                border-radius: 4px;

                ScrollView {
                    width: parent.width;
                    height: parent.height;

                    VerticalBox {
                        alignment: start;
                        padding: root.compact-mode ? 4px : 6px;
                        spacing: root.compact-mode ? 4px : 6px;

                        Text {
                            text: root.active-menu-label;
                            color: root.color-muted;
                            font-size: 11px;
                        }

                        Rectangle { height: 1px; background: root.color-border; }

                        if root.active-menu == 0 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            Button { text: "[O] Open"; clicked => { root.open-document(); root.menu-open = false; } }
                            Button { text: "[S] Save"; enabled: root.has-document; clicked => { root.save-document(); root.menu-open = false; } }
                            Button { text: "[SA] Save As"; enabled: root.has-document; clicked => { root.save-document-as(); root.menu-open = false; } }
                            Button { text: "[X] Close"; enabled: root.has-document; clicked => { root.close-document(); root.menu-open = false; } }
                        }

                        if root.active-menu == 1 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            Button { text: "[U] Undo"; enabled: root.has-document && root.can-undo; clicked => { root.undo(); root.menu-open = false; } }
                            Button { text: "[R] Redo"; enabled: root.has-document && root.can-redo; clicked => { root.redo(); root.menu-open = false; } }
                        }

                        if root.active-menu == 2 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            Button { text: "[-] Zoom -"; enabled: root.has-document; clicked => { root.zoom-out(); root.menu-open = false; } }
                            Button { text: "[+] Zoom +"; enabled: root.has-document; clicked => { root.zoom-in(); root.menu-open = false; } }
                            Button { text: "[1] 100%"; enabled: root.has-document; clicked => { root.zoom-reset(); root.menu-open = false; } }
                        }

                        if root.active-menu == 3 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            Button { text: "[H] Highlight"; enabled: root.has-document; clicked => { root.add-highlight(); root.menu-open = false; } }
                            Button { text: "[N] Note"; enabled: root.has-document; clicked => { root.add-note(); root.menu-open = false; } }
                        }

                        if root.active-menu == 4 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            Button { text: "[<] Prev"; enabled: root.has-document && root.current-page > 1; clicked => { root.prev-page(); root.menu-open = false; } }
                            Button { text: "[>] Next"; enabled: root.has-document && root.current-page < root.page-count; clicked => { root.next-page(); root.menu-open = false; } }
                            Button { text: "[D] Del Page"; enabled: root.has-document; clicked => { root.delete-current-page(); root.menu-open = false; } }
                            Button { text: "[R] Rotate"; enabled: root.has-document; clicked => { root.rotate-current-page(); root.menu-open = false; } }
                        }

                        if root.active-menu == 5 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            Button { text: "[T+] Insert Text"; enabled: root.has-document; clicked => { root.tools-insert-text(); root.menu-open = false; } }
                            Button { text: "[T~] Modify Text"; enabled: root.has-document; clicked => { root.tools-modify-text(); root.menu-open = false; } }
                            Button { text: "[F] Font Sub"; enabled: root.has-document; clicked => { root.tools-font-substitute(); root.menu-open = false; } }
                            Button { text: "[I+] Insert Image"; enabled: root.has-document; clicked => { root.tools-insert-image(); root.menu-open = false; } }
                            Button { text: "[I~] Replace Image"; enabled: root.has-document; clicked => { root.tools-replace-image(); root.menu-open = false; } }
                            Button { text: "[P] Set Password"; enabled: root.has-document; clicked => { root.tools-set-password(); root.menu-open = false; } }
                            Button { text: "[R] Redact"; enabled: root.has-document; clicked => { root.tools-redact-region(); root.menu-open = false; } }
                            Button { text: "[OCR] Apply OCR"; enabled: root.has-document; clicked => { root.tools-apply-ocr(); root.menu-open = false; } }
                            Button { text: "[PG] Reorder"; enabled: root.has-document; clicked => { root.tools-reorder-pages(); root.menu-open = false; } }
                            Button { text: "[M] Merge"; enabled: root.has-document; clicked => { root.tools-merge-document(); root.menu-open = false; } }
                            Button { text: "[C] Create Field"; enabled: root.has-document; clicked => { root.tools-create-field(); root.menu-open = false; } }
                            Button { text: "[S] Set Field"; enabled: root.has-document; clicked => { root.tools-set-field-value(); root.menu-open = false; } }
                            Button { text: "[D] Detect Fields"; enabled: root.has-document; clicked => { root.tools-detect-fields(); root.menu-open = false; } }
                            Button { text: "[E] Export Fields"; enabled: root.has-document; clicked => { root.tools-export-form-data(); root.menu-open = false; } }
                        }

                        if root.active-menu == 6 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            Button { text: "[$] Upgrade"; enabled: root.license-type == "Personal" || root.license-type == "Trial"; clicked => { root.upgrade-license(); root.menu-open = false; } }
                            Button { text: "[A] Activate"; clicked => { root.activate-license(); root.menu-open = false; } }
                        }
                    }
                }
            }
        }
    }
}


