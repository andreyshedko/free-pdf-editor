import { Button, HorizontalBox, VerticalBox, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Free PDF Editor";
    min-width: 900px;
    min-height: 700px;

    in property <image>  page-image;
    in property <string> status-text:   "Ready";
    in property <int>    page-count:    0;
    in property <int>    current-page:  0;
    in property <float>  zoom-level:    1.0;
    in property <bool>   can-undo:      false;
    in property <bool>   can-redo:      false;
    in property <string> document-title: "";
    in property <image>  thumbnail-image;
    property <int> active-menu: 0;

    // License display (read-only from the UI; set by the controller).
    in property <string> license-type:   "Personal";
    in property <string> license-expiry: "";

    callback open-document();
    callback save-document();
    callback save-document-as();
    callback close-document();
    callback zoom-in();
    callback zoom-out();
    callback zoom-reset();
    callback next-page();
    callback prev-page();
    callback undo();
    callback redo();
    callback add-highlight();
    callback add-note();
    callback delete-current-page();
    callback rotate-current-page();
    callback tools-insert-text();
    callback tools-modify-text();
    callback tools-font-substitute();
    callback tools-insert-image();
    callback tools-replace-image();
    callback tools-set-password();
    callback tools-redact-region();
    callback tools-apply-ocr();
    callback tools-reorder-pages();
    callback tools-merge-document();
    callback tools-create-field();
    callback tools-set-field-value();
    callback tools-detect-fields();
    callback tools-export-form-data();
    callback upgrade-license();
    /// Triggered when the user wants to activate a commercial license file.
    /// In debug builds, the controller reads the ACTIVATE_LICENSE environment
    /// variable, validates and reloads. In release builds this action is not
    /// available (file-picker integration is pending).
    callback activate-license();

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: 34px;
            background: #232427;

            HorizontalBox {
                padding-top: 4px;
                padding-bottom: 4px;
                padding-left: 6px;
                padding-right: 6px;
                spacing: 4px;
                alignment: start;

                Button { text: "File";     clicked => { root.active-menu = 0; } }
                Button { text: "Edit";     clicked => { root.active-menu = 1; } }
                Button { text: "View";     clicked => { root.active-menu = 2; } }
                Button { text: "Annotate"; clicked => { root.active-menu = 3; } }
                Button { text: "Page";     clicked => { root.active-menu = 4; } }
                Button { text: "Tools";    clicked => { root.active-menu = 5; } }
                Button { text: "License";  clicked => { root.active-menu = 6; } }

                Rectangle { horizontal-stretch: 1; }

                Text {
                    text: root.document-title == "" ? "Free PDF Editor" : root.document-title;
                    color: #d0d2d6;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 40px;
            background: #34363a;

            HorizontalBox {
                padding-top: 5px;
                padding-bottom: 5px;
                padding-left: 6px;
                padding-right: 6px;
                spacing: 4px;
                alignment: start;

                Button { text: "Open";    visible: root.active-menu == 0; clicked => { root.open-document(); } }
                Button { text: "Save";    visible: root.active-menu == 0; clicked => { root.save-document(); } }
                Button { text: "Save As"; visible: root.active-menu == 0; clicked => { root.save-document-as(); } }
                Button { text: "Close";   visible: root.active-menu == 0; clicked => { root.close-document(); } }

                Button { text: "Undo";    visible: root.active-menu == 1; enabled: root.can-undo; clicked => { root.undo(); } }
                Button { text: "Redo";    visible: root.active-menu == 1; enabled: root.can-redo; clicked => { root.redo(); } }

                Button { text: "Zoom -";  visible: root.active-menu == 2; clicked => { root.zoom-out(); } }
                Button { text: "Zoom +";  visible: root.active-menu == 2; clicked => { root.zoom-in(); } }
                Button { text: "100%";    visible: root.active-menu == 2; clicked => { root.zoom-reset(); } }

                Button { text: "Highlight"; visible: root.active-menu == 3; clicked => { root.add-highlight(); } }
                Button { text: "Note";      visible: root.active-menu == 3; clicked => { root.add-note(); } }

                Button { text: "Prev";     visible: root.active-menu == 4; clicked => { root.prev-page(); } }
                Button { text: "Next";     visible: root.active-menu == 4; clicked => { root.next-page(); } }
                Button { text: "Del Page"; visible: root.active-menu == 4; clicked => { root.delete-current-page(); } }
                Button { text: "Rotate";   visible: root.active-menu == 4; clicked => { root.rotate-current-page(); } }

                Button { text: "Insert Text";    visible: root.active-menu == 5; clicked => { root.tools-insert-text(); } }
                Button { text: "Modify Text";    visible: root.active-menu == 5; clicked => { root.tools-modify-text(); } }
                Button { text: "Font Sub";       visible: root.active-menu == 5; clicked => { root.tools-font-substitute(); } }
                Button { text: "Insert Image";   visible: root.active-menu == 5; clicked => { root.tools-insert-image(); } }
                Button { text: "Replace Image";  visible: root.active-menu == 5; clicked => { root.tools-replace-image(); } }
                Button { text: "Set Password";   visible: root.active-menu == 5; clicked => { root.tools-set-password(); } }
                Button { text: "Redact";         visible: root.active-menu == 5; clicked => { root.tools-redact-region(); } }
                Button { text: "Apply OCR";      visible: root.active-menu == 5; clicked => { root.tools-apply-ocr(); } }
                Button { text: "Reorder";        visible: root.active-menu == 5; clicked => { root.tools-reorder-pages(); } }
                Button { text: "Merge";          visible: root.active-menu == 5; clicked => { root.tools-merge-document(); } }
                Button { text: "Create Field";   visible: root.active-menu == 5; clicked => { root.tools-create-field(); } }
                Button { text: "Set Field";      visible: root.active-menu == 5; clicked => { root.tools-set-field-value(); } }
                Button { text: "Detect Fields";  visible: root.active-menu == 5; clicked => { root.tools-detect-fields(); } }
                Button { text: "Export Fields";  visible: root.active-menu == 5; clicked => { root.tools-export-form-data(); } }

                Button {
                    text: "Upgrade";
                    visible: root.active-menu == 6 && (root.license-type == "Personal" || root.license-type == "Trial");
                    clicked => { root.upgrade-license(); }
                }
                Button { text: "Activate"; visible: root.active-menu == 6; clicked => { root.activate-license(); } }
            }
        }

        HorizontalBox {
            padding: 0px;
            spacing: 0px;

            Rectangle {
                width: 180px;
                background: #f3f4f6;

                VerticalBox {
                    padding: 8px;
                    spacing: 8px;

                    Text {
                        text: "Thumbnail";
                        font-size: 12px;
                        color: #333;
                    }

                    Rectangle {
                        min-height: 240px;
                        background: #e7e8eb;
                        border-width: 1px;
                        border-color: #d2d4d8;

                        Image {
                            width: parent.width;
                            height: parent.height;
                            source: root.thumbnail-image;
                            image-fit: contain;
                        }
                    }
                }
            }

            Rectangle {
                min-width: 800px;

                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    scroll-event(ev) => {
                        if (ev.delta_y < -2px) {
                            root.next-page();
                            return accept;
                        }
                        if (ev.delta_y > 2px) {
                            root.prev-page();
                            return accept;
                        }
                        return reject;
                    }
                }

                ScrollView {
                    width: parent.width;
                    height: parent.height;

                    VerticalBox {
                        alignment: center;
                        padding: 16px;

                        Image {
                            source: root.page-image;
                            image-fit: contain;
                            min-width: 595px;
                            min-height: 842px;
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 26px;
            background: #e5e5ea;

            HorizontalBox {
                padding-top: 4px;
                padding-bottom: 4px;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 16px;
                alignment: start;

                Text {
                    text: root.document-title == "" ? "No document" : root.document-title;
                    font-size: 11px;
                    color: #333;
                }

                Text {
                    text: root.page-count > 0
                        ? "Page " + root.current-page + " / " + root.page-count
                        : "";
                    font-size: 11px;
                    color: #333;
                }

                Text {
                    text: root.status-text;
                    font-size: 11px;
                    color: #555;
                }
            }
        }

        // License info bar – shows license type, expiry date, and upgrade button.
        Rectangle {
            height: 26px;
            background: #f0f0f5;

            HorizontalBox {
                padding-top: 4px;
                padding-bottom: 4px;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 16px;
                alignment: start;

                Text {
                    text: "License: " + root.license-type;
                    font-size: 11px;
                    color: #333;
                }

                Text {
                    text: root.license-expiry != "" ? "Expires: " + root.license-expiry : "";
                    font-size: 11px;
                    color: #777;
                }
            }
        }
    }
}


