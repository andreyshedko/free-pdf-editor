import { Button, CheckBox, ComboBox, HorizontalBox, LineEdit, VerticalBox, ScrollView, Slider } from "std-widgets.slint";

component NativeMenuItem inherits Rectangle {
    in property <string> label: "";
    in property <string> shortcut: "";
    in property <bool> enabled: true;
    in property <bool> dark-theme: true;
    callback activated();

    height: 24px;
    border-radius: 3px;
    border-width: 0px;
    background: !root.enabled ? transparent
        : area.pressed ? (root.dark-theme ? #0a1020 : #cbd5e1)
        : area.has-hover ? (root.dark-theme ? #1f2937 : #e2e8f0)
        : transparent;

    HorizontalBox {
        padding-left: 8px;
        padding-right: 8px;
        alignment: start;
        spacing: 8px;

        Text {
            text: root.label;
            color: root.enabled
                ? (area.pressed ? (root.dark-theme ? #f8fafc : #0f172a)
                    : (root.dark-theme ? #e2e8f0 : #334155))
                : (root.dark-theme ? #64748b : #94a3b8);
            font-size: 12px;
            horizontal-stretch: 1;
            vertical-alignment: center;
        }

        Text {
            text: root.shortcut;
            color: root.enabled
                ? (area.pressed ? (root.dark-theme ? #cbd5e1 : #334155)
                    : (root.dark-theme ? #94a3b8 : #64748b))
                : (root.dark-theme ? #475569 : #94a3b8);
            font-size: 11px;
            horizontal-alignment: right;
            vertical-alignment: center;
        }
    }

    area := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.enabled;
        clicked => {
            root.activated();
        }
    }
}

component RecentPathMenuItem inherits Rectangle {
    in property <string> label: "";
    in property <string> full-label: "";
    in property <string> shortcut: "";
    in property <bool> enabled: true;
    in property <bool> dark-theme: true;
    callback activated();
    callback hover-changed(hovered: bool);
    property <length> shortcut-area-width: 56px;

    height: 24px;
    border-radius: 3px;
    border-width: 0px;
    background: !root.enabled ? transparent
        : area.pressed ? (root.dark-theme ? #0a1020 : #cbd5e1)
        : area.has-hover ? (root.dark-theme ? #1f2937 : #e2e8f0)
        : transparent;

    // Keep the path line within menu width and show a full path tooltip on hover.
    path-text := Text {
        x: 8px;
        width: root.width - root.shortcut-area-width - 12px;
        height: parent.height;
        text: root.label;
        wrap: no-wrap;
        overflow: elide;
        color: root.enabled
            ? (area.pressed ? (root.dark-theme ? #f8fafc : #0f172a)
                : (root.dark-theme ? #e2e8f0 : #334155))
            : (root.dark-theme ? #64748b : #94a3b8);
        font-size: 12px;
        vertical-alignment: center;
    }

    shortcut-text := Text {
        x: root.width - root.shortcut-area-width;
        width: root.shortcut-area-width - 8px;
        height: parent.height;
        text: root.shortcut;
        color: root.enabled
            ? (area.pressed ? (root.dark-theme ? #cbd5e1 : #334155)
                : (root.dark-theme ? #94a3b8 : #64748b))
            : (root.dark-theme ? #475569 : #94a3b8);
        font-size: 11px;
        horizontal-alignment: right;
        vertical-alignment: center;
    }

    if area.has-hover && root.enabled : Rectangle {
        x: root.width + 6px;
        y: -2px;
        width: 460px;
        height: tooltip-text.height + 12px;
        background: root.dark-theme ? #0a1020 : #ffffff;
        border-width: 1px;
        border-color: root.dark-theme ? #334155 : #cbd5e1;
        border-radius: 4px;

        tooltip-text := Text {
            x: 8px;
            y: 6px;
            width: parent.width - 16px;
            text: root.full-label == "" ? root.label : root.full-label;
            wrap: word-wrap;
            color: root.dark-theme ? #e2e8f0 : #334155;
            font-size: 11px;
        }
    }

    area := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.enabled;
        changed has-hover => {
            root.hover-changed(self.has-hover);
        }
        clicked => {
            root.activated();
        }
    }
}

component IconButton inherits Rectangle {
    in property <image> icon;
    in property <string> tooltip-text: "";
    in property <bool> enabled: true;
    in property <bool> dark-theme: true;
    callback clicked();

    width: 32px;
    height: 32px;
    border-radius: 6px;
    background: !root.enabled ? transparent
        : btn-area.pressed ? (root.dark-theme ? #1e3a5f : #bfdbfe)
        : btn-area.has-hover ? (root.dark-theme ? #1e293b : #e2e8f0)
        : transparent;

    Image {
        width: 18px;
        height: 18px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: root.icon;
        colorize: !root.enabled
            ? (root.dark-theme ? #4b5563 : #9ca3af)
            : btn-area.pressed
                ? (root.dark-theme ? #38bdf8 : #0ea5e9)
                : (root.dark-theme ? #e2e8f0 : #334155);
    }

    if btn-area.has-hover && root.tooltip-text != "" : Rectangle {
        x: (parent.width - tt-lbl.preferred-width - 16px) / 2;
        y: parent.height + 4px;
        width: tt-lbl.preferred-width + 16px;
        height: tt-lbl.preferred-height + 8px;
        background: root.dark-theme ? #0a1020 : #ffffff;
        border-width: 1px;
        border-color: root.dark-theme ? #334155 : #cbd5e1;
        border-radius: 4px;
        z: 100;

        tt-lbl := Text {
            x: 8px;
            y: 4px;
            text: root.tooltip-text;
            font-size: 11px;
            color: root.dark-theme ? #e2e8f0 : #334155;
        }
    }

    btn-area := TouchArea {
        width: parent.width;
        height: parent.height;
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

export component AppWindow inherits Window {
    title: root.tr_app_title;
    min-width: 900px;
    min-height: 700px;
    background: root.color-bg;

    in property <image>  page-image;
    in property <string> status-text:   "Ready";
    in property <int>    page-count:    0;
    in property <int>    current-page:  0;
    in property <float>  zoom-level:    1.0;
    in property <float>  page-width:    595.0;
    in property <float>  page-height:   842.0;
    in property <bool>   can-undo:      false;
    in property <bool>   can-redo:      false;
    in property <string> document-title: "";
    in property <image>  thumbnail-image;
    in property <int>    recent-count: 0;
    in property <string> recent-a: "";
    in property <string> recent-b: "";
    in property <string> recent-c: "";
    in property <string> recent-d: "";
    in property <string> recent-e: "";
    in property <string> recent-a-display: "";
    in property <string> recent-b-display: "";
    in property <string> recent-c-display: "";
    in property <string> recent-d-display: "";
    in property <string> recent-e-display: "";
    in property <int>    image-resource-count: 0;
    in property <string> image-resource-a: "";
    in property <string> image-resource-b: "";
    in property <string> image-resource-c: "";
    in property <string> image-resource-d: "";
    in property <string> image-resource-e: "";
    in property <string> image-resource-f: "";
    in property <string> image-resource-g: "";
    in property <string> image-resource-h: "";
    in property <string> image-resource-i: "";
    in property <string> image-resource-j: "";
    in property <bool>   image-resource-has-prev: false;
    in property <bool>   image-resource-has-next: false;
    in property <string> image-resource-page-label: "";
    in property <int>    image-resource-selected-visible-index: -1;
    in property <string> image-resource-selected-name: "";
    in property <bool>   image-edit-controls-visible: false;
    in property <float>  image-edit-controls-x: 0;
    in property <float>  image-edit-controls-y: 0;
    in-out property <string> image-edit-width-text: "";
    in-out property <string> image-edit-height-text: "";
    in-out property <bool>   image-edit-keep-aspect: true;
    in property <bool>   text-edit-controls-visible: false;
    in property <float>  text-edit-controls-x: 0;
    in property <float>  text-edit-controls-y: 0;
    in property <bool>   text-selection-visible: false;
    in property <float>  text-selection-x: 0;
    in property <float>  text-selection-y: 0;
    in property <float>  text-selection-width: 0;
    in property <float>  text-selection-height: 0;
    in property <bool>   text-edit-save-mode: false;
    in-out property <string> text-edit-content-text: "";
    in-out property <string> text-edit-font-text: "Helvetica";
    in-out property <string> text-edit-size-text: "14";
    property <[string]> text-font-model: [
        "Helvetica",
        "Helvetica-Bold",
        "Helvetica-Oblique",
        "Helvetica-BoldOblique",
        "Times-Roman",
        "Times-Bold",
        "Times-Italic",
        "Times-BoldItalic",
        "Courier",
        "Courier-Bold",
        "Courier-Oblique",
        "Courier-BoldOblique"
    ];
    in property <bool>   image-drag-active: false;
    in property <bool>   dark-theme: true;
    property <int> active-menu: 0;
    property <bool> compact-mode: false;
    property <bool> menu-open: false;
    property <bool> tools-image-submenu-open: false;
    property <bool> file-open-recent-row-hover: false;
    property <bool> file-open-recent-menu-hover: false;
    property <bool> file-open-recent-bridge-hover: false;
    property <bool> file-open-recent-visible: root.file-open-recent-row-hover || root.file-open-recent-menu-hover || root.file-open-recent-bridge-hover;
    property <bool> has-document: root.page-count > 0;
    property <length> menu-button-width: root.compact-mode ? 86px : 96px;
    property <length> menu-row-spacing: root.compact-mode ? 6px : 8px;
    property <length> header-height: root.compact-mode ? 72px : 86px;
    property <int> menu-content-count:
        root.active-menu == 0 ? 6 :
        root.active-menu == 1 ? 2 :
        root.active-menu == 2 ? 3 :
        root.active-menu == 3 ? 2 :
        root.active-menu == 4 ? 4 :
        root.active-menu == 5 ? 13 :
        2;
    property <length> menu-dropdown-height:
        ((root.menu-content-count + 2) * (root.compact-mode ? 24px : 28px)) + (root.compact-mode ? 14px : 16px);
    property <[string]> menu-model: [root.tr_menu_file, root.tr_menu_edit, root.tr_menu_view, root.tr_menu_annotate, root.tr_menu_page, root.tr_menu_tools, root.tr_menu_license];
    property <string> active-menu-label:
        root.active-menu == 0 ? root.tr_menu_file :
        root.active-menu == 1 ? root.tr_menu_edit :
        root.active-menu == 2 ? root.tr_menu_view :
        root.active-menu == 3 ? root.tr_menu_annotate :
        root.active-menu == 4 ? root.tr_menu_page :
        root.active-menu == 5 ? root.tr_menu_tools :
        root.tr_menu_license;
    property <string> shortcut-tooltip:
        root.active-menu == 0 ? "Open: Ctrl+O\nSave: Ctrl+S\nSave As: Ctrl+Shift+S\nClose: Ctrl+W" :
        root.active-menu == 1 ? "Undo: Ctrl+Z\nRedo: Ctrl+Y" :
        root.active-menu == 2 ? "Zoom In: Ctrl+=\nZoom Out: Ctrl+-\n100%: Ctrl+0" :
        root.active-menu == 3 ? "Highlight: Ctrl+H\nNote: Ctrl+J" :
        root.active-menu == 4 ? "Previous: PgUp\nNext: PgDn\nDelete Page: Del\nRotate Page: Ctrl+R" :
        root.active-menu == 5 ? "Insert Text: Ctrl+T\nFont Sub: Ctrl+Shift+F\nInsert Image: Ctrl+I\nPassword: Ctrl+P\nRedact: Ctrl+Shift+X\nOCR: Ctrl+Shift+O\nReorder: Ctrl+Shift+G\nMerge: Ctrl+M\nCreate Field: Ctrl+Shift+N\nSet Value: Ctrl+Shift+V\nDetect: Ctrl+Shift+D\nExport: Ctrl+Shift+E" :
        "";

    property <brush> color-bg: root.dark-theme ? #0b1220 : #f8fafc;
    property <brush> color-header: root.dark-theme ? #111827 : #f1f5f9;
    property <brush> color-header-2: root.dark-theme ? #1f2937 : #e2e8f0;
    property <brush> color-panel: root.dark-theme ? #0f172a : #ffffff;
    property <brush> color-panel-soft: root.dark-theme ? #1e293b : #f8fafc;
    property <brush> color-border: root.dark-theme ? #334155 : #cbd5e1;
    property <brush> color-text: root.dark-theme ? #e2e8f0 : #0f172a;
    property <brush> color-muted: root.dark-theme ? #94a3b8 : #64748b;
    property <brush> color-accent: root.dark-theme ? #38bdf8 : #0ea5e9;
    property <brush> color-canvas: root.dark-theme ? #0b1220 : #e2e8f0;
    property <brush> color-menu-hover: root.dark-theme ? #1f2937 : #e2e8f0;
    property <brush> color-menu-active: root.dark-theme ? #0a1020 : #cbd5e1;

    // License display (read-only from the UI; set by the controller).
    in property <string> license-type:   "Personal";
    in property <string> license-expiry: "";

    // Localized UI strings.
    in property <string> tr_app_title: "Free PDF Editor";
    in property <string> tr_no_document: "No document";
    in property <string> tr_page_preview: "Page Preview";
    in property <string> tr_current_prefix: "Current";
    in property <string> tr_no_document_loaded: "No document loaded";
    in property <string> tr_page_prefix: "Page";
    in property <string> tr_license_prefix: "License";
    in property <string> tr_expires_prefix: "Expires";
    in property <string> tr_open_recent: "Open Recent";
    in property <string> tr_no_recent_files: "No recent files";
    in property <string> tr_click_image_to_edit: "Click image on page to edit";
    in property <string> tr_width_short: "W";
    in property <string> tr_height_short: "H";
    in property <string> tr_lock_aspect: "Lock aspect";
    in property <string> tr_apply: "Apply";
    in property <string> tr_text: "Text";
    in property <string> tr_font: "Font";
    in property <string> tr_size: "Size";
    in property <string> tr_insert: "Insert";
    in property <string> tr_close: "Close";
    in property <string> tr_zoom: "Zoom";

    in property <string> tr_menu_file: "File";
    in property <string> tr_menu_edit: "Edit";
    in property <string> tr_menu_view: "View";
    in property <string> tr_menu_annotate: "Annotate";
    in property <string> tr_menu_page: "Page";
    in property <string> tr_menu_tools: "Tools";
    in property <string> tr_menu_license: "License";

    in property <string> tr_open: "Open";
    in property <string> tr_save: "Save";
    in property <string> tr_save_as: "Save As";
    in property <string> tr_undo: "Undo";
    in property <string> tr_redo: "Redo";
    in property <string> tr_reset_100: "Reset 100%";
    in property <string> tr_highlight: "Highlight";
    in property <string> tr_note: "Note";
    in property <string> tr_previous: "Previous";
    in property <string> tr_next: "Next";
    in property <string> tr_delete_page: "Delete Page";
    in property <string> tr_rotate_page: "Rotate Page";
    in property <string> tr_insert_text: "Insert Text";
    in property <string> tr_font_substitute: "Font Substitute";
    in property <string> tr_insert_image: "Insert Image";
    in property <string> tr_set_password: "Set Password";
    in property <string> tr_redact: "Redact";
    in property <string> tr_apply_ocr: "Apply OCR";
    in property <string> tr_reorder_pages: "Reorder Pages";
    in property <string> tr_merge: "Merge";
    in property <string> tr_create_field: "Create Field";
    in property <string> tr_set_field_value: "Set Field Value";
    in property <string> tr_detect_fields: "Detect Fields";
    in property <string> tr_export_fields: "Export Fields";
    in property <string> tr_upgrade: "Upgrade";
    in property <string> tr_activate: "Activate";

    callback open-document();
    callback open-recent(index: int);
    callback save-document();
    callback save-document-as();
    callback close-document();
    callback zoom-in();
    callback zoom-out();
    callback zoom-reset();
    callback zoom-set(factor: float);
    callback next-page();
    callback prev-page();
    callback undo();
    callback redo();
    callback add-highlight();
    callback add-note();
    callback delete-current-page();
    callback rotate-current-page();
    callback tools-insert-text();
    callback tools-modify-text();
    callback tools-font-substitute();
    callback tools-insert-image();
    callback tools-replace-image();
    callback tools-edit-image-resource(index: int);
    callback tools-clear-image-selection();
    callback image-edit-rotate90();
    callback image-edit-flip();
    callback image-edit-delete();
    callback image-edit-apply-size(width-text: string, height-text: string, keep-aspect: bool);
    callback text-edit-insert(content-text: string, font-text: string, size-text: string);
    callback text-edit-delete();
    callback text-edit-close();
    callback text-edit-font-changed(font-text: string);
    callback tools-image-resource-prev-page();
    callback tools-image-resource-next-page();
    callback tools-set-password();
    callback tools-redact-region();
    callback tools-apply-ocr();
    callback tools-reorder-pages();
    callback tools-merge-document();
    callback tools-create-field();
    callback tools-set-field-value();
    callback tools-detect-fields();
    callback tools-export-form-data();
    callback upgrade-license();
    /// Triggered when the user wants to activate a commercial license file.
    /// In debug builds, the controller reads the ACTIVATE_LICENSE environment
    /// variable, validates and reloads. In release builds this action is not
    /// available (file-picker integration is pending).
    callback activate-license();
    callback menu-action-selected(menu-index: int, action-index: int);
    callback canvas-clicked(x: float, y: float);
    callback canvas-double-clicked(x: float, y: float);
    callback canvas-press-start(x: float, y: float);
    callback canvas-press-move(x: float, y: float);
    callback canvas-press-end(x: float, y: float);
    forward-focus: keyboard_scope;

    init => {
        root.compact-mode = root.width < 1160px;
    }

    changed width => {
        root.compact-mode = root.width < 1160px;
    }

    changed menu-open => {
        if (!root.menu-open) {
            root.tools-image-submenu-open = false;
            root.file-open-recent-row-hover = false;
            root.file-open-recent-menu-hover = false;
            root.file-open-recent-bridge-hover = false;
        }
    }

    changed active-menu => {
        if (root.active-menu != 5) {
            root.tools-image-submenu-open = false;
        }
        if (root.active-menu != 0) {
            root.file-open-recent-row-hover = false;
            root.file-open-recent-menu-hover = false;
            root.file-open-recent-bridge-hover = false;
        }
    }

    keyboard_scope := FocusScope {
        width: parent.width;
        height: parent.height;

        key-pressed(event) => {
            if (event.text == Key.Escape && root.menu-open) {
                root.menu-open = false;
                return accept;
            }

            if (event.modifiers.control && event.modifiers.shift && (event.text == "S" || event.text == "s")) {
                root.save-document-as();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && (event.text == "O" || event.text == "o")) {
                root.open-document();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && (event.text == "S" || event.text == "s")) {
                root.save-document();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && (event.text == "Z" || event.text == "z")) {
                root.undo();
                return accept;
            }

            if (event.modifiers.meta && !event.modifiers.shift && (event.text == "Z" || event.text == "z")) {
                root.undo();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && (event.text == "Y" || event.text == "y")) {
                root.redo();
                return accept;
            }

            if (event.modifiers.meta && !event.modifiers.shift && (event.text == "Y" || event.text == "y")) {
                root.redo();
                return accept;
            }

            if (event.modifiers.control && event.modifiers.shift && (event.text == "Z" || event.text == "z")) {
                root.redo();
                return accept;
            }

            if (event.modifiers.meta && event.modifiers.shift && (event.text == "Z" || event.text == "z")) {
                root.redo();
                return accept;
            }

            if (event.modifiers.control && (event.text == "+" || event.text == "=")) {
                root.zoom-in();
                return accept;
            }

            if (event.modifiers.control && event.text == "-") {
                root.zoom-out();
                return accept;
            }

            if (event.modifiers.control && event.text == Key.UpArrow) {
                root.zoom-in();
                return accept;
            }

            if (event.modifiers.control && event.text == Key.DownArrow) {
                root.zoom-out();
                return accept;
            }

            if (event.modifiers.control && event.text == "0") {
                root.zoom-reset();
                return accept;
            }

            if (event.text == Key.PageDown || event.text == Key.RightArrow) {
                root.next-page();
                return accept;
            }

            if (event.text == Key.PageUp || event.text == Key.LeftArrow) {
                root.prev-page();
                return accept;
            }

            // Close document
            if (event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt && (event.text == "W" || event.text == "w")) {
                root.close-document();
                return accept;
            }

            // Open recent files (Alt+1..5)
            if (event.modifiers.alt && event.text == "1") { root.open-recent(0); return accept; }
            if (event.modifiers.alt && event.text == "2") { root.open-recent(1); return accept; }
            if (event.modifiers.alt && event.text == "3") { root.open-recent(2); return accept; }
            if (event.modifiers.alt && event.text == "4") { root.open-recent(3); return accept; }
            if (event.modifiers.alt && event.text == "5") { root.open-recent(4); return accept; }

            // Annotate shortcuts
            if (event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt && (event.text == "H" || event.text == "h")) {
                root.add-highlight();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt && (event.text == "J" || event.text == "j")) {
                root.add-note();
                return accept;
            }

            // Page shortcuts
            if (!event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt && event.text == Key.Delete) {
                root.delete-current-page();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt && (event.text == "R" || event.text == "r")) {
                root.rotate-current-page();
                return accept;
            }

            // Tools shortcuts
            if (event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt && (event.text == "T" || event.text == "t")) {
                root.tools-insert-text();
                return accept;
            }

            if (event.modifiers.control && event.modifiers.shift && !event.modifiers.alt && (event.text == "F" || event.text == "f")) {
                root.tools-font-substitute();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt && (event.text == "I" || event.text == "i")) {
                root.tools-insert-image();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt && (event.text == "P" || event.text == "p")) {
                root.tools-set-password();
                return accept;
            }

            if (event.modifiers.control && event.modifiers.shift && !event.modifiers.alt && (event.text == "X" || event.text == "x")) {
                root.tools-redact-region();
                return accept;
            }

            if (event.modifiers.control && event.modifiers.shift && !event.modifiers.alt && (event.text == "O" || event.text == "o")) {
                root.tools-apply-ocr();
                return accept;
            }

            if (event.modifiers.control && event.modifiers.shift && !event.modifiers.alt && (event.text == "G" || event.text == "g")) {
                root.tools-reorder-pages();
                return accept;
            }

            if (event.modifiers.control && !event.modifiers.shift && !event.modifiers.alt && (event.text == "M" || event.text == "m")) {
                root.tools-merge-document();
                return accept;
            }

            if (event.modifiers.control && event.modifiers.shift && !event.modifiers.alt && (event.text == "N" || event.text == "n")) {
                root.tools-create-field();
                return accept;
            }

            if (event.modifiers.control && event.modifiers.shift && !event.modifiers.alt && (event.text == "V" || event.text == "v")) {
                root.tools-set-field-value();
                return accept;
            }

            if (event.modifiers.control && event.modifiers.shift && !event.modifiers.alt && (event.text == "D" || event.text == "d")) {
                root.tools-detect-fields();
                return accept;
            }

            if (event.modifiers.control && event.modifiers.shift && !event.modifiers.alt && (event.text == "E" || event.text == "e")) {
                root.tools-export-form-data();
                return accept;
            }

            return reject;
        }

        VerticalBox {
        padding: 0px;
        spacing: 0px;

        Rectangle {
            height: root.header-height;
            background: root.color-header;
            border-width: 1px;
            border-color: root.color-border;
            animate height { duration: 180ms; }

            VerticalBox {
                padding-top: root.compact-mode ? 6px : 8px;
                padding-bottom: root.compact-mode ? 6px : 8px;
                padding-left: root.compact-mode ? 8px : 10px;
                padding-right: root.compact-mode ? 8px : 10px;
                spacing: root.compact-mode ? 4px : 6px;

                HorizontalBox {
                    spacing: 10px;

                    Text {
                        text: root.tr_app_title;
                        color: root.color-text;
                        font-size: root.compact-mode ? 13px : 15px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }

                    Text {
                        text: root.document-title == "" ? root.tr_no_document : root.document-title;
                        color: root.color-muted;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                HorizontalBox {
                    spacing: root.menu-row-spacing;
                    alignment: start;

                    for menu_name[idx] in root.menu-model : Rectangle {
                        width: root.menu-button-width;
                        height: root.compact-mode ? 26px : 28px;
                        border-radius: 4px;
                        border-width: root.menu-open && root.active-menu == idx ? 1px : 0px;
                        border-color: root.color-border;
                        background: root.menu-open && root.active-menu == idx ? root.color-menu-active : transparent;

                        Text {
                            text: menu_name;
                            color: root.menu-open && root.active-menu == idx ? root.color-text : root.color-muted;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            width: parent.width;
                            height: parent.height;
                            clicked => {
                                if (root.active-menu == idx) {
                                    root.menu-open = !root.menu-open;
                                } else {
                                    root.active-menu = idx;
                                    root.menu-open = true;
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 0px;
            background: transparent;
        }

        Rectangle {
            height: 2px;
            background: root.color-accent;
        }

        // ── Icon toolbar ─────────────────────────────────────────────────────
        Rectangle {
            height: root.compact-mode ? 36px : 40px;
            background: root.color-header-2;
            border-width: 1px;
            border-color: root.color-border;
            animate height { duration: 180ms; }

            HorizontalBox {
                padding-left: root.compact-mode ? 6px : 8px;
                padding-right: root.compact-mode ? 6px : 8px;
                padding-top: root.compact-mode ? 2px : 4px;
                padding-bottom: root.compact-mode ? 2px : 4px;
                spacing: 2px;
                alignment: start;

                IconButton { icon: @image-url("icons/open.svg"); tooltip-text: root.tr_open + " (Ctrl+O)"; dark-theme: root.dark-theme; clicked => { root.open-document(); } }
                IconButton { icon: @image-url("icons/save.svg"); tooltip-text: root.tr_save + " (Ctrl+S)"; dark-theme: root.dark-theme; enabled: root.has-document; clicked => { root.save-document(); } }

                Rectangle { width: 1px; height: root.compact-mode ? 20px : 24px; background: root.color-border; }

                IconButton { icon: @image-url("icons/undo.svg"); tooltip-text: root.tr_undo + " (Ctrl+Z)"; dark-theme: root.dark-theme; enabled: root.has-document && root.can-undo; clicked => { root.undo(); } }
                IconButton { icon: @image-url("icons/redo.svg"); tooltip-text: root.tr_redo + " (Ctrl+Y)"; dark-theme: root.dark-theme; enabled: root.has-document && root.can-redo; clicked => { root.redo(); } }

                Rectangle { width: 1px; height: root.compact-mode ? 20px : 24px; background: root.color-border; }

                IconButton { icon: @image-url("icons/zoom-in.svg"); tooltip-text: root.tr_zoom + " + (Ctrl+=)"; dark-theme: root.dark-theme; enabled: root.has-document; clicked => { root.zoom-in(); } }
                IconButton { icon: @image-url("icons/zoom-out.svg"); tooltip-text: root.tr_zoom + " - (Ctrl+-)"; dark-theme: root.dark-theme; enabled: root.has-document; clicked => { root.zoom-out(); } }

                Rectangle { width: 1px; height: root.compact-mode ? 20px : 24px; background: root.color-border; }

                IconButton { icon: @image-url("icons/prev-page.svg"); tooltip-text: root.tr_previous + " (PgUp)"; dark-theme: root.dark-theme; enabled: root.has-document && root.current-page > 1; clicked => { root.prev-page(); } }
                IconButton { icon: @image-url("icons/next-page.svg"); tooltip-text: root.tr_next + " (PgDn)"; dark-theme: root.dark-theme; enabled: root.has-document && root.current-page < root.page-count; clicked => { root.next-page(); } }

                Rectangle { width: 1px; height: root.compact-mode ? 20px : 24px; background: root.color-border; }

                IconButton { icon: @image-url("icons/insert-text.svg"); tooltip-text: root.tr_insert_text + " (Ctrl+T)"; dark-theme: root.dark-theme; enabled: root.has-document; clicked => { root.tools-insert-text(); } }
                IconButton { icon: @image-url("icons/insert-image.svg"); tooltip-text: root.tr_insert_image + " (Ctrl+I)"; dark-theme: root.dark-theme; enabled: root.has-document; clicked => { root.tools-insert-image(); } }
                IconButton { icon: @image-url("icons/highlight.svg"); tooltip-text: root.tr_highlight + " (Ctrl+H)"; dark-theme: root.dark-theme; enabled: root.has-document; clicked => { root.add-highlight(); } }
                IconButton { icon: @image-url("icons/note.svg"); tooltip-text: root.tr_note + " (Ctrl+J)"; dark-theme: root.dark-theme; enabled: root.has-document; clicked => { root.add-note(); } }
                IconButton { icon: @image-url("icons/rotate.svg"); tooltip-text: root.tr_rotate_page + " (Ctrl+R)"; dark-theme: root.dark-theme; enabled: root.has-document; clicked => { root.rotate-current-page(); } }
                IconButton { icon: @image-url("icons/delete.svg"); tooltip-text: root.tr_delete_page + " (Del)"; dark-theme: root.dark-theme; enabled: root.has-document; clicked => { root.delete-current-page(); } }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            background: transparent;

            HorizontalBox {
                padding: 0px;
                spacing: 0px;

                Rectangle {
                    width: root.compact-mode ? 178px : 220px;
                    background: root.color-panel;
                    border-width: 1px;
                    border-color: root.color-border;
                    animate width { duration: 180ms; }

                VerticalBox {
                    padding: root.compact-mode ? 8px : 12px;
                    spacing: root.compact-mode ? 6px : 10px;

                    Text {
                        text: root.tr_page_preview;
                        font-size: 13px;
                        font-weight: 600;
                        color: root.color-text;
                    }

                    Text {
                        text: root.page-count > 0 ? root.tr_current_prefix + ": " + root.current-page + " / " + root.page-count : root.tr_no_document_loaded;
                        font-size: 11px;
                        color: root.color-muted;
                    }

                    Rectangle {
                        min-height: root.compact-mode ? 170px : 240px;
                        background: root.color-panel-soft;
                        border-width: 1px;
                        border-color: root.color-border;
                        border-radius: 8px;
                        animate min-height { duration: 180ms; }

                        Image {
                            width: parent.width;
                            height: parent.height;
                            source: root.thumbnail-image;
                            image-fit: contain;
                        }
                    }
                }
                }

                Rectangle {
                    min-width: 800px;
                    background: root.color-canvas;
                    border-width: 1px;
                    border-color: root.color-border;

                    ScrollView {
                        width: parent.width;
                        height: parent.height;

                        VerticalBox {
                            alignment: center;
                            padding: root.compact-mode ? 14px : 24px;
                            animate padding { duration: 180ms; }

                            Rectangle {
                                border-width: 1px;
                                border-color: root.color-border;
                                border-radius: 10px;
                                background: root.dark-theme ? #0f172a : #ffffff;
                                VerticalBox {
                                    padding: 12px;
                                    spacing: 0px;

                                    Rectangle {
                                        width: root.page-width * 1px * root.zoom-level;
                                        height: root.page-height * 1px * root.zoom-level;
                                        background: transparent;

                                        Image {
                                            width: parent.width;
                                            height: parent.height;
                                            source: root.page-image;
                                            image-fit: fill;
                                        }

                                        Rectangle {
                                            visible: root.text-selection-visible;
                                            x: root.text-selection-x * 1px;
                                            y: root.text-selection-y * 1px;
                                            width: root.text-selection-width * 1px;
                                            height: root.text-selection-height * 1px;
                                            border-width: 3px;
                                            border-color: #f59e0b;
                                            border-radius: 4px;
                                            background: #f59e0b33;
                                        }

                                        TouchArea {
                                            width: parent.width;
                                            height: parent.height;
                                            enabled: true;
                                            mouse-cursor: root.image-drag-active ? MouseCursor.grabbing : MouseCursor.default;
                                            scroll-event(ev) => {
                                                if (ev.delta_y < -2px) {
                                                    root.next-page();
                                                    return accept;
                                                }
                                                if (ev.delta_y > 2px) {
                                                    root.prev-page();
                                                    return accept;
                                                }
                                                return reject;
                                            }
                                            changed pressed => {
                                                let mx = self.mouse-x / 1px;
                                                let my = self.mouse-y / 1px;
                                                if (self.pressed) {
                                                    root.canvas-press-start(mx, my);
                                                } else {
                                                    root.canvas-press-end(mx, my);
                                                }
                                            }
                                            moved => {
                                                if (self.pressed) {
                                                    root.canvas-press-move(self.mouse-x / 1px, self.mouse-y / 1px);
                                                }
                                            }
                                            double-clicked => {
                                                let mx = self.mouse-x / 1px;
                                                let my = self.mouse-y / 1px;
                                                root.canvas-double-clicked(mx, my);
                                            }
                                        }

                                        Rectangle {
                                            visible: root.image-edit-controls-visible;
                                            opacity: root.image-edit-controls-visible ? 1 : 0;
                                            x: root.image-edit-controls-x * 1px;
                                            y: (root.image-edit-controls-y + (root.image-edit-controls-visible ? 0 : 6)) * 1px;
                                            width: 540px;
                                            height: 124px;
                                            border-width: 1px;
                                            border-color: root.color-border;
                                            border-radius: 8px;
                                            background: root.color-panel;
                                            animate opacity { duration: 140ms; }
                                            animate x { duration: 140ms; }
                                            animate y { duration: 140ms; }

                                            HorizontalBox {
                                                padding: 6px;
                                                spacing: 6px;

                                                Rectangle {
                                                    width: 28px;
                                                    height: 28px;
                                                    border-width: 1px;
                                                    border-color: root.color-border;
                                                    border-radius: 5px;
                                                    background: root.color-panel-soft;
                                                    Path {
                                                        x: 5px;
                                                        y: 5px;
                                                        width: 18px;
                                                        height: 18px;
                                                        commands: "M 9 2 A 7 7 0 1 1 2.3 11 M 9 2 L 12 2 M 12 2 L 12 5";
                                                        stroke: root.color-text;
                                                        stroke-width: 1.5px;
                                                        fill: transparent;
                                                    }
                                                    TouchArea {
                                                        width: parent.width;
                                                        height: parent.height;
                                                        clicked => { root.image-edit-rotate90(); }
                                                    }
                                                }

                                                Rectangle {
                                                    width: 28px;
                                                    height: 28px;
                                                    border-width: 1px;
                                                    border-color: root.color-border;
                                                    border-radius: 5px;
                                                    background: root.color-panel-soft;
                                                    Path {
                                                        x: 4px;
                                                        y: 8px;
                                                        width: 20px;
                                                        height: 12px;
                                                        commands: "M 2 6 L 18 6 M 2 6 L 6 2 M 2 6 L 6 10 M 18 6 L 14 2 M 18 6 L 14 10";
                                                        stroke: root.color-text;
                                                        stroke-width: 1.5px;
                                                        fill: transparent;
                                                    }
                                                    TouchArea {
                                                        width: parent.width;
                                                        height: parent.height;
                                                        clicked => { root.image-edit-flip(); }
                                                    }
                                                }

                                                Rectangle {
                                                    width: 28px;
                                                    height: 28px;
                                                    border-width: 1px;
                                                    border-color: root.color-border;
                                                    border-radius: 5px;
                                                    background: root.color-panel-soft;
                                                    Path {
                                                        x: 6px;
                                                        y: 5px;
                                                        width: 16px;
                                                        height: 18px;
                                                        commands: "M 1 4 L 15 4 M 4 4 L 5 16 L 11 16 L 12 4 M 6 4 L 6 2 L 10 2 L 10 4 M 7 7 L 7 13 M 9 7 L 9 13";
                                                        stroke: root.color-text;
                                                        stroke-width: 1.2px;
                                                        fill: transparent;
                                                    }
                                                    TouchArea {
                                                        width: parent.width;
                                                        height: parent.height;
                                                        clicked => { root.image-edit-delete(); }
                                                    }
                                                }

                                                VerticalBox {
                                                    spacing: 4px;

                                                    HorizontalBox {
                                                        spacing: 4px;
                                                        Text { text: root.tr_width_short; color: root.color-muted; font-size: 11px; vertical-alignment: center; }
                                                        LineEdit {
                                                            width: 74px;
                                                            text: root.image-edit-width-text;
                                                            edited => { root.image-edit-width-text = self.text; }
                                                        }
                                                        Text { text: root.tr_height_short; color: root.color-muted; font-size: 11px; vertical-alignment: center; }
                                                        LineEdit {
                                                            width: 74px;
                                                            text: root.image-edit-height-text;
                                                            edited => { root.image-edit-height-text = self.text; }
                                                        }
                                                        CheckBox {
                                                            text: root.tr_lock_aspect;
                                                            checked: root.image-edit-keep-aspect;
                                                            toggled => { root.image-edit-keep-aspect = self.checked; }
                                                        }
                                                        Button {
                                                            width: 72px;
                                                            text: root.tr_apply;
                                                            clicked => {
                                                                root.image-edit-apply-size(
                                                                    root.image-edit-width-text,
                                                                    root.image-edit-height-text,
                                                                    root.image-edit-keep-aspect
                                                                );
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        Rectangle {
                                            visible: root.text-edit-controls-visible;
                                            opacity: root.text-edit-controls-visible ? 1 : 0;
                                            x: max(4px, min(root.text-edit-controls-x * 1px, parent.width - self.width - 4px));
                                            y: max(4px, min((root.text-edit-controls-y + (root.text-edit-controls-visible ? 0 : 6)) * 1px, parent.height - self.height - 4px));
                                            // Keep the text panel inside the page viewport so
                                            // the font-size field and action buttons stay visible.
                                            width: min(parent.width - 10px, root.compact-mode ? 560px : 760px);
                                            height: min(parent.height - 10px, root.compact-mode ? 176px : 162px);
                                            border-width: 1px;
                                            border-color: root.color-border;
                                            border-radius: 8px;
                                            background: root.color-panel;
                                            animate opacity { duration: 140ms; }
                                            animate x { duration: 140ms; }
                                            animate y { duration: 140ms; }

                                            ScrollView {
                                                width: parent.width;
                                                height: parent.height;

                                                VerticalBox {
                                                    padding: 4px;
                                                    spacing: 3px;

                                                    HorizontalBox {
                                                        spacing: 6px;
                                                        Text { text: root.tr_text; color: root.color-muted; font-size: 11px; vertical-alignment: center; }
                                                        LineEdit {
                                                            horizontal-stretch: 1;
                                                            text: root.text-edit-content-text;
                                                            edited => { root.text-edit-content-text = self.text; }
                                                        }
                                                    }

                                                    HorizontalBox {
                                                        spacing: 6px;
                                                        Text { text: root.tr_font; color: root.color-muted; font-size: 11px; vertical-alignment: center; }
                                                        ComboBox {
                                                            horizontal-stretch: 1;
                                                            model: root.text-font-model;
                                                            current-value: root.text-edit-font-text;
                                                            selected(value) => {
                                                                root.text-edit-font-text = value;
                                                                root.text-edit-font-changed(value);
                                                            }
                                                        }
                                                        Text { text: root.tr_size; color: root.color-muted; font-size: 11px; vertical-alignment: center; }
                                                        LineEdit {
                                                            width: 88px;
                                                            text: root.text-edit-size-text;
                                                            edited => { root.text-edit-size-text = self.text; }
                                                        }
                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            background: transparent;
                                                        }
                                                    }

                                                    HorizontalBox {
                                                        spacing: 6px;
                                                        Rectangle {
                                                            horizontal-stretch: 1;
                                                            background: transparent;
                                                        }
                                                        Button {
                                                            width: root.compact-mode ? 86px : 96px;
                                                            text: root.text-edit-save-mode ? root.tr_save : root.tr_insert;
                                                            clicked => {
                                                                root.text-edit-insert(
                                                                    root.text-edit-content-text,
                                                                    root.text-edit-font-text,
                                                                    root.text-edit-size-text
                                                                );
                                                            }
                                                        }
                                                        if root.text-edit-save-mode : Rectangle {
                                                            width: 28px;
                                                            height: 28px;
                                                            border-width: 1px;
                                                            border-color: root.color-border;
                                                            border-radius: 5px;
                                                            background: root.color-panel-soft;
                                                            Path {
                                                                x: 6px;
                                                                y: 5px;
                                                                width: 16px;
                                                                height: 18px;
                                                                commands: "M 1 4 L 15 4 M 4 4 L 5 16 L 11 16 L 12 4 M 6 4 L 6 2 L 10 2 L 10 4 M 7 7 L 7 13 M 9 7 L 9 13";
                                                                stroke: root.color-text;
                                                                stroke-width: 1.2px;
                                                                fill: transparent;
                                                            }
                                                            TouchArea {
                                                                width: parent.width;
                                                                height: parent.height;
                                                                clicked => { root.text-edit-delete(); }
                                                            }
                                                        }
                                                        Button {
                                                            width: root.compact-mode ? 70px : 76px;
                                                            text: root.tr_close;
                                                            clicked => { root.text-edit-close(); }
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                    }
                                }
                            }
                        }
                    }
                }
            }

            if root.menu-open : TouchArea {
                width: parent.width;
                height: parent.height;
                clicked => {
                    root.menu-open = false;
                }
            }
        }

        Rectangle {
            height: root.compact-mode ? 24px : 30px;
            background: root.color-header;
            border-width: 1px;
            border-color: root.color-border;
            animate height { duration: 180ms; }

            HorizontalBox {
                padding-top: 4px;
                padding-bottom: 4px;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 16px;
                alignment: start;

                Text {
                    text: root.document-title == "" ? root.tr_no_document : root.document-title;
                    font-size: 11px;
                    color: root.color-text;
                }

                Text {
                    text: root.page-count > 0
                        ? root.tr_page_prefix + " " + root.current-page + " / " + root.page-count
                        : "";
                    font-size: 11px;
                    color: root.color-muted;
                }

                Text {
                    text: root.status-text;
                    font-size: 11px;
                    color: root.color-accent;
                }
            }
        }

        // License info bar – shows license type, expiry date, and upgrade button.
        Rectangle {
            height: root.compact-mode ? 24px : 30px;
            background: #101a2d;
            border-width: 1px;
            border-color: root.color-border;
            animate height { duration: 180ms; }

            HorizontalBox {
                padding-top: 4px;
                padding-bottom: 4px;
                padding-left: 8px;
                padding-right: 8px;
                spacing: 16px;
                alignment: start;

                Text {
                    text: root.tr_license_prefix + ": " + root.license-type;
                    font-size: 11px;
                    color: root.color-text;
                }

                Text {
                    text: root.license-expiry != "" ? root.tr_expires_prefix + ": " + root.license-expiry : "";
                    font-size: 11px;
                    color: root.color-muted;
                }
            }
        }

        }

        // Global dropdown overlay (rendered last) so it stays above all UI layers,
        // similar to appending a menu body to document body in web apps.
        if root.menu-open : Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: transparent;

            // Click outside closes the menu.
            TouchArea {
                width: parent.width;
                y: root.header-height;
                height: parent.height - root.header-height;
                clicked => { root.menu-open = false; }
            }

            Rectangle {
                x: (root.compact-mode ? 8px : 10px) + root.active-menu * (root.menu-button-width + root.menu-row-spacing);
                y: root.header-height;
                width: root.active-menu == 5
                    ? (root.compact-mode ? 372px : 420px)
                    : (root.compact-mode ? 128px : 150px);
                height: root.menu-dropdown-height;
                background: root.color-panel;
                border-width: 1px;
                border-color: root.color-border;
                border-radius: 4px;

                ScrollView {
                    width: parent.width;

                    VerticalBox {
                        alignment: start;
                        padding: root.compact-mode ? 4px : 6px;
                        spacing: root.compact-mode ? 4px : 6px;

                        Text {
                            text: root.active-menu-label;
                            color: root.color-muted;
                            font-size: 11px;
                        }

                        Rectangle { height: 1px; background: root.color-border; }

                        if root.active-menu == 0 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_open; shortcut: "Ctrl+O"; activated => { root.open-document(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_save; shortcut: "Ctrl+S"; enabled: root.has-document; activated => { root.save-document(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_save_as; shortcut: "Ctrl+Shift+S"; enabled: root.has-document; activated => { root.save-document-as(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_close; shortcut: "Ctrl+W"; enabled: root.has-document; activated => { root.close-document(); root.menu-open = false; } }
                            Rectangle { height: 1px; background: root.color-border; }
                            Rectangle {
                                height: 24px;
                                border-radius: 3px;
                                background: open_recent_hover.has-hover ? root.color-menu-hover : transparent;

                                HorizontalBox {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    Text {
                                        text: root.tr_open_recent;
                                        color: root.color-text;
                                        font-size: 12px;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: "▶";
                                        color: root.color-muted;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }

                                open_recent_hover := TouchArea {
                                    width: parent.width;
                                    height: parent.height;
                                    changed has-hover => {
                                        root.file-open-recent-row-hover = self.has-hover;
                                    }
                                }
                            }
                        }

                        if root.active-menu == 1 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_undo; shortcut: "Ctrl+Z"; enabled: root.has-document && root.can-undo; activated => { root.undo(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_redo; shortcut: "Ctrl+Y"; enabled: root.has-document && root.can-redo; activated => { root.redo(); root.menu-open = false; } }
                        }

                        if root.active-menu == 2 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            Text {
                                text: root.tr_zoom + " " + (root.zoom-level * 100%) + "%";
                                color: root.color-text;
                                font-size: 11px;
                            }
                            Slider {
                                enabled: root.has-document;
                                minimum: 0.25;
                                maximum: 4.0;
                                value: root.zoom-level;
                                changed value => {
                                    root.zoom-set(self.value);
                                }
                            }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_reset_100; shortcut: "Ctrl+0"; enabled: root.has-document; activated => { root.zoom-reset(); root.menu-open = false; } }
                        }

                        if root.active-menu == 3 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_highlight; shortcut: "Ctrl+H"; enabled: root.has-document; activated => { root.add-highlight(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_note; shortcut: "Ctrl+J"; enabled: root.has-document; activated => { root.add-note(); root.menu-open = false; } }
                        }

                        if root.active-menu == 4 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_previous; shortcut: "PgUp"; enabled: root.has-document && root.current-page > 1; activated => { root.prev-page(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_next; shortcut: "PgDn"; enabled: root.has-document && root.current-page < root.page-count; activated => { root.next-page(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_delete_page; shortcut: "Del"; enabled: root.has-document; activated => { root.delete-current-page(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_rotate_page; shortcut: "Ctrl+R"; enabled: root.has-document; activated => { root.rotate-current-page(); root.menu-open = false; } }
                        }

                        if root.active-menu == 5 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_insert_text; shortcut: "Ctrl+T"; enabled: root.has-document; activated => { root.tools-insert-text(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_font_substitute; shortcut: "Ctrl+Shift+F"; enabled: root.has-document; activated => { root.tools-font-substitute(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_insert_image; shortcut: "Ctrl+I"; enabled: root.has-document; activated => { root.tools-insert-image(); root.menu-open = false; } }
                            Text { text: root.tr_click_image_to_edit; color: root.color-muted; font-size: 11px; }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_set_password; shortcut: "Ctrl+P"; enabled: root.has-document; activated => { root.tools-set-password(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_redact; shortcut: "Ctrl+Shift+X"; enabled: root.has-document; activated => { root.tools-redact-region(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_apply_ocr; shortcut: "Ctrl+Shift+O"; enabled: root.has-document; activated => { root.tools-apply-ocr(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_reorder_pages; shortcut: "Ctrl+Shift+G"; enabled: root.has-document; activated => { root.tools-reorder-pages(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_merge; shortcut: "Ctrl+M"; enabled: root.has-document; activated => { root.tools-merge-document(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_create_field; shortcut: "Ctrl+Shift+N"; enabled: root.has-document; activated => { root.tools-create-field(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_set_field_value; shortcut: "Ctrl+Shift+V"; enabled: root.has-document; activated => { root.tools-set-field-value(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_detect_fields; shortcut: "Ctrl+Shift+D"; enabled: root.has-document; activated => { root.tools-detect-fields(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_export_fields; shortcut: "Ctrl+Shift+E"; enabled: root.has-document; activated => { root.tools-export-form-data(); root.menu-open = false; } }
                        }

                        if root.active-menu == 6 : VerticalBox {
                            spacing: root.compact-mode ? 4px : 6px;
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_upgrade; shortcut: "$"; enabled: root.license-type == "Personal" || root.license-type == "Trial"; activated => { root.upgrade-license(); root.menu-open = false; } }
                            NativeMenuItem { dark-theme: root.dark-theme; label: root.tr_activate; shortcut: "A"; activated => { root.activate-license(); root.menu-open = false; } }
                        }
                    }
                }
            }

            if root.active-menu == 0 && root.file-open-recent-visible : Rectangle {
                x: (root.compact-mode ? 8px : 10px)
                    + (root.compact-mode ? 128px : 150px)
                    - 2px;
                y: root.header-height + (root.compact-mode ? 136px : 150px);
                width: root.compact-mode ? 250px : 300px;
                background: root.color-panel;
                border-width: 1px;
                border-color: root.color-border;
                border-radius: 4px;

                VerticalBox {
                    padding: 6px;
                    spacing: 4px;

                    if root.recent-count == 0 : Text {
                        text: root.tr_no_recent_files;
                        color: root.color-muted;
                        font-size: 11px;
                    }
                    if root.recent-count > 0 : RecentPathMenuItem { width: root.compact-mode ? 238px : 288px; dark-theme: root.dark-theme; label: root.recent-a-display; full-label: root.recent-a; shortcut: "Alt+1"; hover-changed(hovered) => { root.file-open-recent-menu-hover = hovered; } activated => { root.open-recent(0); root.menu-open = false; } }
                    if root.recent-count > 1 : RecentPathMenuItem { width: root.compact-mode ? 238px : 288px; dark-theme: root.dark-theme; label: root.recent-b-display; full-label: root.recent-b; shortcut: "Alt+2"; hover-changed(hovered) => { root.file-open-recent-menu-hover = hovered; } activated => { root.open-recent(1); root.menu-open = false; } }
                    if root.recent-count > 2 : RecentPathMenuItem { width: root.compact-mode ? 238px : 288px; dark-theme: root.dark-theme; label: root.recent-c-display; full-label: root.recent-c; shortcut: "Alt+3"; hover-changed(hovered) => { root.file-open-recent-menu-hover = hovered; } activated => { root.open-recent(2); root.menu-open = false; } }
                    if root.recent-count > 3 : RecentPathMenuItem { width: root.compact-mode ? 238px : 288px; dark-theme: root.dark-theme; label: root.recent-d-display; full-label: root.recent-d; shortcut: "Alt+4"; hover-changed(hovered) => { root.file-open-recent-menu-hover = hovered; } activated => { root.open-recent(3); root.menu-open = false; } }
                    if root.recent-count > 4 : RecentPathMenuItem { width: root.compact-mode ? 238px : 288px; dark-theme: root.dark-theme; label: root.recent-e-display; full-label: root.recent-e; shortcut: "Alt+5"; hover-changed(hovered) => { root.file-open-recent-menu-hover = hovered; } activated => { root.open-recent(4); root.menu-open = false; } }
                }
            }

            if root.active-menu == 0 && root.file-open-recent-visible : TouchArea {
                // Hover bridge prevents submenu from disappearing while crossing
                // the tiny gap between "Open Recent" row and recent-files panel.
                x: (root.compact-mode ? 8px : 10px)
                    + (root.compact-mode ? 128px : 150px)
                    - 8px;
                y: root.header-height + (root.compact-mode ? 136px : 150px);
                width: 12px;
                height: root.compact-mode ? 180px : 220px;
                changed has-hover => {
                    root.file-open-recent-bridge-hover = self.has-hover;
                }
            }
        }

    }
}



