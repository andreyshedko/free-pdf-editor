{
  "name": "free-pdf-editor",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform desktop PDF editor built with Electron, React, and JavaScript.",
  "main": "electron/src/main.js",
  "scripts": {
    "dev": "concurrently -n electron,renderer -c blue,green \"npm:dev:electron\" \"npm:dev:renderer\"",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev:renderer": "vite --config vite.config.js",
    "build": "npm run build:renderer",
    "build:renderer": "vite build --config vite.config.js",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "test": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "fabric": "^7.2.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.624",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react-swc": "^4.1.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^40.6.1",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
